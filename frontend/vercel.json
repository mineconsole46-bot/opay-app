{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/account/resolve", "destination": "/api/account/resolve" },
    { "source": "/api/banks", "destination": "/api/banks" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
